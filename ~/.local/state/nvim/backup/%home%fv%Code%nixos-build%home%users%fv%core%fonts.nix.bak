
{ config, lib, pkgs, ... }:
{
  fonts = {
    fontconfig = {
      enable = true;
      allowBitmaps = true;
    };

    packages = with pkgs; [
      liberation_ttf
      freefont_ttf
      unifont
      dejavu_fonts
      fira-code
      fira-code-symbols
      noto-fonts
      noto-fonts-color-emoji
      noto-fonts-cjk-sans
      font-awesome
      jetbrains-mono
      material-icons
      maple-mono.NF
      nerd-fonts.fira-code
      nerd-fonts.droid-sans-mono
      nerd-fonts.jetbrains-mono
      nerd-fonts.meslo-lg
      nerd-fonts.hack
      terminus_font
      inter
    ];
  };
}
